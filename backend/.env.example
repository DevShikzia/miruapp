# ─── Servidor ─────────────────────────────────────
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:4200

# ─── Base de datos ────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/miru

# ─── JWT ──────────────────────────────────────────
JWT_SECRET= cambiar_por_clave_segura_64_chars_min
JWT_REFRESH_SECRET= cambiar_por_otra_clave_segura_64_chars_min
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── Superadmin (seed) ────────────────────────────
SUPERADMIN_EMAIL=admin@miru.app
SUPERADMIN_PASSWORD= cambiar_por_clave_segura

# ─── Google OAuth ─────────────────────────────────
GOOGLE_CLIENT_ID=123456789-xxxxx.apps.googleusercontent.com

# ─── Push notifications (VAPID) ───────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@miru.app
